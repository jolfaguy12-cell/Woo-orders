# Store information (used in PDF header)
FONT_PATH=./fonts/Vazirmatn-Regular.ttf
STORE_NAME=نام فروشگاه شما
STORE_PHONE=021-12345678
STORE_ADDRESS=تهران، خیابان ولیعصر، کوچه نمونه، پلاک ۱
STORE_POSTCODE=1234567890
SITE_URL=https://yoursite.com

# Telegram bot
TG_BOT_TOKEN=your_telegram_bot_token_here
# Telegram admin chat ID — only this user can manage notification destinations
# Default is 213946880; override here only if the admin changes
TG_ADMIN_ID=213946880
# Path to JSON file storing configured notification destinations (gitignored)
TG_DESTINATIONS_FILE=telegram_destinations.json

# Order processing rules
# Comma-separated WooCommerce status slugs that trigger a Telegram notification.
# Default covers standard "processing". Add your store's custom Persian status slug
# after checking: WooCommerce > Settings > Order Statuses (or via WC API /statuses).
# Example custom slug for "آماده‌سازی برای ارسال": wc-ready-to-ship
TARGET_ORDER_STATUSES=processing,wc-ready-to-ship

# Basalam detection: comma-separated order meta key names checked for basalam values
BASALAM_META_KEYS=_order_source,source,channel,known_source,_basalam_order_id

# State database (SQLite) — stores order status + sent Telegram message IDs
# Keep under data/ so it stays gitignored automatically
ORDER_STATE_DB=./data/order_state.sqlite3
# Number of days to retain processed order records
STATE_RETENTION_DAYS=30

# WooCommerce API — required only for backup.py (bulk PDF export)
WC_URL=https://yoursite.com
WC_KEY=ck_your_consumer_key
WC_SECRET=cs_your_consumer_secret
