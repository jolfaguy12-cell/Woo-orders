# Store information (used in PDF header)
FONT_PATH=./fonts/Vazirmatn-Regular.ttf
STORE_NAME=نام فروشگاه شما
STORE_PHONE=021-12345678
STORE_ADDRESS=تهران، خیابان ولیعصر، کوچه نمونه، پلاک ۱
STORE_POSTCODE=1234567890
SITE_URL=https://yoursite.com

# Telegram bot
TG_BOT_TOKEN=your_telegram_bot_token_here
# Telegram admin chat ID — only this user can manage notification destinations
# Default is 213946880; override here only if the admin changes
TG_ADMIN_ID=213946880
# Path to JSON file storing configured notification destinations (gitignored)
TG_DESTINATIONS_FILE=telegram_destinations.json

# Order processing rules
# Comma-separated WooCommerce status slugs that trigger a Telegram notification.
# Hub strips the "wc-" prefix before delivering the webhook (wc-bslm-preparation → bslm-preparation).
# The app also normalizes raw wc-* statuses as a safety net.
# Standard WC: processing, completed, refunded, cancelled, pending, on-hold, ready-to-ship
# Basalam statuses (confirmed from mirror DB):
#   bslm-preparation  — آماده‌سازی سفارش باسلام
#   bslm-shipping     — سفارش برای مشتری باسلام
#   bslm-rejected     — لغو شده باسلام
#   bslm-wait-vendor  — انتظار فروشنده
#   refunded          — مسترد شده (standard WC, also used for Basalam returns)
# bslm-completed is intentionally excluded: completed Basalam orders generate no notification.
TARGET_ORDER_STATUSES=processing,ready-to-ship,bslm-preparation,bslm-shipping,bslm-wait-vendor,bslm-rejected,refunded

# State database (SQLite) — stores order status + sent Telegram message IDs
# Keep under data/ so it stays gitignored automatically
ORDER_STATE_DB=./data/order_state.sqlite3
# Number of days to retain processed order records
STATE_RETENTION_DAYS=30

# Webhook server — receives order events from the Hub
# Copy the secret shown in the Hub dashboard (Webhooks → woo-orders → Secret)
WEBHOOK_SECRET=your_hub_webhook_secret_here
# Port for the webhook HTTP server; must NOT be 5000 (Hub itself uses 5000)
WEBHOOK_PORT=5100
