# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Environment — keep only the example
.env
.env.*
!.env.example

# Generated output
output/
backup_pdfs/
*.zip

# Runtime state and config (sensitive)
data/
*.db
*.sqlite3
telegram_destinations.json

# WordPress data hub order cache (not committed)
wordpress-data-hub/cache/

# Fonts (large binaries; add your own)
fonts/

# OS / editors
.DS_Store
*.log
.idea/
.vscode/

# Pip install artifacts (e.g. =3.0.0 from malformed install command)
=*
